# lessons.json is loaded server-side only (not a public download).
<IfModule mod_authz_core.c>
    <Files "lessons.json">
        Require all denied
    </Files>
</IfModule>
<IfModule !mod_authz_core.c>
    <Files "lessons.json">
        Order deny,allow
        Deny from all
    </Files>
</IfModule>
